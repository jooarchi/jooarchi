rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "jooheegul@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Document ID: projectId
    // Fields:
    //   - id: number (required)
    //   - title: string (required)
    //   - location: string (required)
    //   - year: string (required)
    //   - category: string (required)
    //   - scale: string (required)
    //   - images: list of strings (required)
    //   - description: string (optional)

    // Collection: settings
    // Document ID: global
    // Fields:
    //   - aboutText: string
    //   - contactEmail: string
    //   - contactAddress: string
    //   - homeIntroText: string
    //   - isUnderConstruction: boolean
    //   - underConstructionImage: string
    //   - underConstructionText: string

    match /projects/{projectId} {
      allow read: if true;
      allow write: if true; // Publicly writable as requested to bypass Auth domain issues
    }

    match /settings/global {
      allow read: if true;
      allow write: if true; // Publicly writable as requested to bypass Auth domain issues
    }
  }
}
